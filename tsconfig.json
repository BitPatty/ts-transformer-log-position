{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "exactOptionalPropertyTypes": true,
    "incremental": true,
    "module": "es2020",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "sourceRoot": "./src",
    "removeComments": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2020",
    "typeRoots": [
      "./node_modules/@types",
      "src/types"
    ],
    "types": [
      "node",
      "jest"
    ],
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "./*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "rollup.config.mjs"
  ]
}